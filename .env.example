# Copy to .env and adjust. .env is gitignored.

# PostgreSQL connection string
DATABASE_URL="postgresql://USER@localhost:5432/deskbench?schema=public"

# LLM (OpenAI-compatible endpoint; OpenRouter by default). Only needed for the
# assistant + eval paths — the core app and rule/ML baselines do not require it.
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://openrouter.ai/api/v1"
